{
  "name": "klennycode",
  "version": "0.2.0",
  "description": "Klenny Code — a desktop coding agent powered by OpenRouter, with memory, skills, subagents, and plan mode.",
  "main": "./out/main/index.js",
  "author": "Dan Tahir <dantahir@gmail.com>",
  "homepage": "https://github.com/DanTahir/KlennyCode",
  "license": "MIT",
  "private": true,
  "type": "module",
  "overrides": {
    "vectra": {
      "uuid": "11.1.0"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:tsc": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "start": "electron-vite preview",
    "icons": "npx tsx scripts/generate-icons.ts",
    "test": "npx bun test",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.15.14",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "cron-parser": "^5.6.2",
    "diff": "^7.0.0",
    "discord.js": "^14.27.0",
    "electron-updater": "^6.3.9",
    "fast-glob": "^3.3.3",
    "googleapis": "^173.0.0",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.6",
    "nanoid": "^5.0.9",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0",
    "simple-git": "^3.27.0",
    "vectra": "^0.15.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.dantahir.klennycode",
    "productName": "Klenny Code",
    "executableName": "KlennyCode",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/icons/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/@vscode/ripgrep/**",
      "**/node_modules/@vscode/ripgrep-*/**",
      "**/node_modules/node-pty/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "DanTahir",
      "repo": "KlennyCode",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons/icon.png",
      "category": "Development",
      "maintainer": "Dan Tahir <dantahir@gmail.com>",
      "synopsis": "Desktop coding agent",
      "description": "Klenny Code — a desktop coding agent powered by OpenRouter, with memory, skills, subagents, and plan mode."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
